{
  "expo": {
    "name": "Travel Food",
    "slug": "travel-food-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "golocal",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.golocal.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GoLocal uses your location to find restaurants near you and deliver to your address.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GoLocal uses your location to find restaurants near you and deliver to your address."
      }
    },
    "android": {
      "package": "com.golocal.customer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B35"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.golocal.customer",
          "enableGooglePay": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GoLocal uses your location to find restaurants near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
